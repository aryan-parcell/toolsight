rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    // Basic check for signed-in user
    function isSignedIn() {
      return request.auth != null;
    }

    // Fetch the user's profile
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if the user has a specific role (e.g., 'admin', 'maintainer')
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Does the doc belong to the user's (active) org?
    // This relies on 'organizationId' existing on the document itself
    // Validates auth, org ownership, AND active billing in one swoop.
    function hasActiveOrgAccess(docData) {
      let user = getUserData();
      let isSameOrg = docData.organizationId == user.organizationId;
      let isSubActive = get(/databases/$(database)/documents/organizations/$(user.organizationId)).data.subscriptionStatus == 'active';
      
      return isSignedIn() && isSameOrg && isSubActive;
    }

    function onlyFieldsUpdated(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // One-use functions for simplicity in rules

    function userUpdateValid() {
      return onlyFieldsUpdated(['fcmToken', 'lastLogin']);
    }

    function auditUpdateValid() {
      return onlyFieldsUpdated(['drawerStates']);
    }

    // --- COLLECTION RULES ---

    match /demo_bookings/{docId} {
      // Allow anyone to submit a lead
      allow create: if true; 
      // Only admins can read/delete them
      allow read, update, delete: if hasRole('admin'); 
    }

    match /organizations/{orgId} {
      // Anyone can read their own organization data.
      allow read: if getUserData().organizationId == orgId;

      // Only created via backend
      allow create: if false; 
    }

    match /invitations/{invitationId} {                                                                                                                                             
      allow read, delete: if hasRole('admin') && hasActiveOrgAccess(resource.data);  
                                                                                                     
      allow create: if false; // Managed by Cloud Functions                                                                                                                         
    } 

    match /users/{userId} {
      // Users can read their own profile, and admins can read any profile in their org.
      allow read: if (isSignedIn() && request.auth.uid == userId) || (hasRole('admin') && hasActiveOrgAccess(resource.data));
      
      // Only created via backend
      allow create: if false;
      allow update: if isSignedIn() && request.auth.uid == userId && userUpdateValid();
    }

    match /templates/{templateId} {
      // Anyone in the organization can read templates.
      allow read: if hasActiveOrgAccess(resource.data);

      // Only 'admin' users can create, update, or delete templates.
      allow create: if hasRole('admin') && hasActiveOrgAccess(request.resource.data);
      allow update: if hasRole('admin') && hasActiveOrgAccess(request.resource.data) && hasActiveOrgAccess(resource.data);
      allow delete: if hasRole('admin') && hasActiveOrgAccess(resource.data);
    }

    match /toolboxes/{toolboxId} {
      // Anyone in the organization can read toolboxes.
      allow read: if hasActiveOrgAccess(resource.data);

      // Only 'admin' users can create, update, or delete toolboxes.
      allow create: if hasRole('admin') && hasActiveOrgAccess(request.resource.data);
      allow update: if hasRole('admin') && hasActiveOrgAccess(request.resource.data) && hasActiveOrgAccess(resource.data);
      allow delete: if hasRole('admin') && hasActiveOrgAccess(resource.data);
    }

    match /checkouts/{checkoutId} {
      // Anyone in the organization can read checkouts.
      allow read: if hasActiveOrgAccess(resource.data);

      // Managed by Cloud Functions
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Audits: Must match Org ID.
    match /audits/{auditId} {
      allow read: if hasActiveOrgAccess(resource.data);
      allow create: if hasActiveOrgAccess(request.resource.data) && hasRole('admin'); // Admin can create initial audits; others managed by Cloud Functions
      allow update: if hasActiveOrgAccess(resource.data) && auditUpdateValid();
    }
  }
}